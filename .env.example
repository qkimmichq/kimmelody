# Kimmelody 配置

# 服务端口
PORT=8080

# 网易云音乐 API 地址（需自行启动 NeteaseCloudMusicApi）
NETEASE_API_BASE=http://localhost:3000

# Fish Audio TTS API Key（https://fish.audio）
FISH_AUDIO_API_KEY=

# OpenWeatherMap API Key（https://openweathermap.org/api）
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Beijing

# AI 模型配置（Anthropic 兼容 API，支持 DeepSeek 等）
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_MODEL=deepseek-v4-pro

# 日历类型（ical | feishu），不配置则跳过日程
CALENDAR_TYPE=
CALENDAR_PATH=./data/calendar.ics

# 数据文件路径（通常无需修改）
STATE_DB_PATH=./data/state.db
TASTE_PATH=./data/taste.md
ROUTINES_PATH=./data/routines.md
DJ_PERSONA_PATH=./data/dj-persona.md
TTS_CACHE_DIR=./cache/tts
WEB_DIR=./packages/web/public
